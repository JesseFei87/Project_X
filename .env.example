MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=minimax-m3
MINIMAX_TEMPERATURE=0.1
MINIMAX_MAX_TOKENS=1400

# openai: OpenAI-compatible /chat/completions
# minimax-cn: MiniMax国内常见 /text/chatcompletion_v2?GroupId=xxx
MINIMAX_API_STYLE=minimax-cn

# 国内版常见配置，如果你的控制台给了完整地址，优先填 MINIMAX_ENDPOINT
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_CHAT_PATH=/text/chatcompletion_v2
MINIMAX_GROUP_ID=your_group_id
# MINIMAX_ENDPOINT=https://api.minimax.chat/v1/text/chatcompletion_v2?GroupId=your_group_id

# 如果你的 Token Plan 控制台要求不同鉴权头，可以改这里
MINIMAX_AUTH_HEADER=Authorization
MINIMAX_AUTH_PREFIX=Bearer

# Agent模式安全限制
AGENT_HEADLESS=true
AGENT_ALLOWED_HOSTS=*
AGENT_STEP_DELAY_MS=700
AGENT_MINIMAX_MAX_TOKENS=4096

# Browser Use 实验性对照
# 需要 Python 3.11+，并安装 requirements-browser-use.txt
# 如果 MiniMax 国内地址不是 OpenAI-compatible，请单独提供兼容地址
BROWSER_USE_MODEL=minimax-m3
# BROWSER_USE_API_KEY=your_openai_compatible_key
# BROWSER_USE_BASE_URL=https://your-openai-compatible-base-url/v1
# BROWSER_USE_PYTHON=.venv/bin/python
# BROWSER_USE_CONFIG_DIR=.browser-use/config
# BROWSER_USE_MAX_STEPS=500
BROWSER_USE_HEADLESS=true
BROWSER_USE_ENABLE_DEFAULT_EXTENSIONS=false
BROWSER_USE_VISION=false
